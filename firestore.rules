
rules_version = '2';
 
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isUserAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      // Use lowercase for robust comparison and support database roles
      return isUserAuthenticated() && (
        request.auth.token.email.lower() == 'vidyaheist@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isMicroAdmin() {
      return isUserAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'microadmin';
    }
 
    match /users/{userId} {
      allow read: if isUserAuthenticated();
      allow create, update: if isOwner(userId);
    }

    match /testSeries/{seriesId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /tests/{testId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();

        match /questions/{questionId} {
          allow read: if true;
          allow create, update, delete: if isAdmin();
        }
      }
    }

    match /purchases/{purchaseId} {
      // Users can read their own orders, Admin can read all
      allow read: if isUserAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      // Only users can create their own orders
      allow create: if isUserAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Only admin can update order status (verify/reject)
      allow update: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isUserAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isUserAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Results collection - Students save their final score
    match /results/{resultId} {
      // Allowing read for all authenticated users for the leaderboard
      allow read: if isUserAuthenticated();
      // Only owner can create it
      allow create: if isUserAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Only owner can perform other operations (though we mostly only need read/create)
      allow update, delete: if isUserAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Exam progress - Periodic auto-saves while taking the test
    match /examProgress/{progressId} {
      // progressId is {userId}_{testId}
      allow read, write: if isUserAuthenticated() && (progressId.split('_')[0] == request.auth.uid);
    }

    // Secure Books collection
    match /books/{bookId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isUserAuthenticated();
        allow update, delete: if isAdmin();
      }
    }

    // Secure Book Orders collection
    match /bookOrders/{orderId} {
      allow read: if isUserAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin() || isMicroAdmin());
      allow create: if isUserAuthenticated() && 
        request.resource.data.userId == request.auth.uid && 
        request.resource.data.status == 'pending';
      allow update: if isAdmin() || 
        (isUserAuthenticated() && resource.data.userId == request.auth.uid && 
         resource.data.status == 'pending' && 
         request.resource.data.status == 'rejected') ||
        (isMicroAdmin() && 
          resource.data.status != 'pending' && 
          resource.data.status != 'rejected' &&
          (request.resource.data.status == 'processing' || 
           request.resource.data.status == 'shipped' || 
           request.resource.data.status == 'delivered') &&
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.bookId == resource.data.bookId
        );
    }

    // Secure Counselling Leads collection
    match /counsellingQueries/{queryId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
